#!/usr/bin/env bash

shopt -s nullglob

# Searches for a valid agent socket containing keys
#
# Usage:
#   source <($0)
__find_ssh_agent_socket() {
  local -a try_socks=("$SSH_AUTH_SOCK" /tmp/ssh-*/agent.*)

  for sock in "${try_socks[@]}"; do
    SSH_AUTH_SOCK=$sock
    if ssh-add -l &>/dev/null; then 
      echo "SSH_AUTH_SOCK=$sock"
      return
    fi
  done
  return 1
}

__find_ssh_agent_socket "$@"
