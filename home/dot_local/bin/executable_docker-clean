#!/usr/bin/env bash

set -eu

if command -v docker &>/dev/null; then
  docker rm -v $(docker ps --filter=status=exited --filter=status=created -q) 2>/dev/null
  docker rmi $(docker images -a --filter=dangling=true -q) 2>/dev/null
  docker volume rm $(docker volume ls --filter=dangling=true -q) 2>/dev/null
elif command -v podman &>/dev/null; then
  podman rm -v $(podman ps --filter=status=exited --filter=status=created --external -q) 2>/dev/null || true
  podman rmi $(podman images -a --filter=dangling=true -q) 2>/dev/null || true
  podman volume rm $(podman volume ls --filter=dangling=true -q) 2>/dev/null || true
fi
