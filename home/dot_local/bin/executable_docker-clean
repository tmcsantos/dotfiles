#!/usr/bin/env bash

set -eu

docker_=docker

if command -v docker &>/dev/null; then
  docker_=docker
elif command -v podman &>/dev/null; then
  docker_=podman
fi


$docker_ rm -v "$($docker_ ps --filter=status=exited --filter=status=created -q)" 2>/dev/null
$docker_ rmi "$($docker_ images -a --filter=dangling=true -q)" 2>/dev/null
$docker_ volume rm "$($docker_ volume ls --filter=dangling=true -q)" 2>/dev/null
